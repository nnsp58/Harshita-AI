{
  "sites": [
    {
      "id": "ssc",
      "name": "SSC CGL/CHSL",
      "baseUrl": "https://ssc.gov.in",
      "formUrl": "https://ssc.gov.in/registration",
      "fieldSelectors": {
        "fullName": "xpath=//label[contains(text(),'2. Candidate Name')]/following::input[1]",
        "fatherName": "xpath=//label[contains(text(),\"6. Father's Name\")]/following::input[1]",
        "motherName": "xpath=//label[contains(text(),\"7. Mother's Name\")]/following::input[1]",
        "dob": "input[formControlName='dob']",
        "gender": "xpath=//label[contains(text(),'4. Gender')]/following::div[contains(@class,'Select')]",
        "email": "xpath=//label[contains(text(),\"13. Candidate's Email ID\")]/following::input[1]",
        "phone": "xpath=//label[contains(text(),\"12. Candidate's Mobile Number\")]/following::input[1]",
        "aadhaar": "input[placeholder*='e.g. 526262627262']",
        "state": "xpath=//label[contains(text(),'State/UT')]/following::mat-select[1]",
        "district": "xpath=//label[contains(text(),'District')]/following::mat-select[1]",
        "pincode": "xpath=//label[contains(text(),'Pin Code')]/following::input[1]"
      },
      "requiredDocuments": ["photo", "signature", "aadhaar", "pan", "categoryCertificate", "incomeCertificate"],
      "hasCaptcha": true,
      "hasOtp": true,
      "delayConfig": {
        "minDelay": 1500,
        "maxDelay": 3500
      },
      "userAgentRotation": true,
      "submitSelector": "button[type='submit'], input[type='submit'], button:has-text('Submit'), button:has-text('Register')",
      "successIndicator": {
        "selector": ".success-message, .alert-success, #successMessage",
        "text": ["submitted successfully", "registration successful", "application received", "success"]
      },
      "customScript": null
    },

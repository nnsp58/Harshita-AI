# Production Environment Variables for HARSHITA AI BRAIN
# Copy this to .env and update with your actual values

# ========================================
# APPLICATION CONFIGURATION
# ========================================
NODE_ENV=production
PORT=3000
CORS_ORIGIN=https://your-domain.com

# ========================================
# DATABASE CONFIGURATION
# ========================================
# SQLite for production (recommended for single server)
DATABASE_URL="file:./data/prod.db"

# PostgreSQL alternative (for multi-server setup)
# DATABASE_URL="postgresql://username:password@localhost:5432/harshita_ai_prod"

# ========================================
# SECURITY CONFIGURATION
# ========================================
# Generate a strong JWT secret: openssl rand -base64 32
JWT_SECRET=your-super-secure-jwt-secret-here-change-this-in-production
JWT_EXPIRES_IN=24h

# ========================================
# AI PROVIDER CONFIGURATION
# ========================================
# Primary AI Provider - Groq (Free, Fast)
GROQ_API_KEY=your-groq-api-key-here

# Secondary AI Provider - Gemini (High Quality, Paid)
GEMINI_API_KEY=your-gemini-api-key-here

# Fallback AI Provider - OpenRouter (Free Models)
OPENROUTER_API_KEY=your-openrouter-api-key-here
MISTRAL_API_KEY=your-mistral-api-key-here

# OpenAI as last resort (Expensive)
OPENAI_API_KEY=your-openai-api-key-here

# ========================================
# FILE UPLOAD CONFIGURATION
# ========================================
UPLOAD_DIR=./uploads
PROCESSED_DIR=./processed
MAX_FILE_SIZE=10485760

# ========================================
# RATE LIMITING
# ========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# ========================================
# REDIS CONFIGURATION
# ========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ========================================
# EMAIL CONFIGURATION (Optional)
# ========================================
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password

# ========================================
# EXTERNAL SERVICE INTEGRATION
# ========================================
# n8n Workflow Automation (Optional)
N8N_BASE_URL=http://localhost:5678

# Webhook for notifications (Optional)
NOTIFICATION_WEBHOOK_URL=

# ========================================
# LOGGING CONFIGURATION
# ========================================
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# ========================================
# SSL CONFIGURATION (Auto-configured by Let's Encrypt)
# ========================================
SSL_CERT_PATH=/etc/letsencrypt/live/your-domain.com/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/your-domain.com/privkey.pem

# ========================================
# ADMIN CONFIGURATION
# ========================================
# Default admin credentials (change after first login)
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=change-this-password-immediately

# ========================================
# BACKUP CONFIGURATION
# ========================================
BACKUP_DIR=/opt/backups/harshita-ai-brain
BACKUP_RETENTION_DAYS=7

# ========================================
# MONITORING & ANALYTICS
# ========================================
# Application monitoring
ENABLE_PROMETHEUS_METRICS=false
METRICS_PORT=9090

# Error tracking (Optional)
SENTRY_DSN=

# ========================================
# CSC INTEGRATION (Government Services)
# ========================================
CSC_API_ENDPOINT=https://csc.gov.in/api
CSC_API_KEY=

# State-specific configurations
UP_BHULEKH_URL=https://upbhulekh.gov.in/
BIHAR_BHULEKH_URL=http://biharbhumi.bihar.gov.in/Biharbhumi/
RAJASTHAN_BHULEKH_URL=https://apnakhata.raj.nic.in/

# ========================================
# PERFORMANCE TUNING
# ========================================
# Database connection pool
DB_MAX_CONNECTIONS=10
DB_IDLE_TIMEOUT=30000

# AI request timeouts
AI_REQUEST_TIMEOUT=30000
AI_MAX_RETRIES=3

# File processing limits
MAX_CONCURRENT_UPLOADS=5
MAX_CONCURRENT_AI_REQUESTS=10

# ========================================
# DEVELOPMENT OVERRIDES (Remove in production)
# ========================================
# DEBUG=true
# LOG_LEVEL=debug